{
  "manifest_version": 3,
  "name": "PromptVault Pro",
  "version": "1.0.0",
  "description": "Remember every prompt. Improve every interaction.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://grok.x.com/*",
    "https://x.com/*",
    "https://copilot.microsoft.com/*",
    "https://api.promptvault.app/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/claude.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/gemini.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/perplexity.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*", "https://grok.x.com/*", "https://x.com/i/grok*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/grok.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": [
        "src/content_scripts/injector.js",
        "src/content_scripts/paste_engine.js",
        "src/content_scripts/platforms/copilot.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P"
      },
      "description": "Open PromptVault Pro"
    }
  },

  "web_accessible_resources": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://grok.x.com/*",
        "https://x.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "resources": [
        "src/popup/index.html",
        "assets/*"
      ],
      "use_dynamic_url": false
    }
  ]
}
